# ─────────────────────────────────────────────
#  OS junk
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────────
#  Editor / IDE noise
# ─────────────────────────────────────────────
*.swp
*.swo
*~
.idea/
.vscode/

# ─────────────────────────────────────────────
#  Backups created by bootstrap scripts
# ─────────────────────────────────────────────
*.backup
*.bak

# ─────────────────────────────────────────────
#  Per-machine override files — never commit
# ─────────────────────────────────────────────
bashrc.local
*.local
# per-machine nvim overrides (paths, compiler)
nvim/lua/config/local.lua

# ─────────────────────────────────────────────
#  Nvim runtime data (downloaded, not config)
#  - nvim-pack-lock.json IS tracked (intentionally not ignored)
#    so plugin revisions are pinned/reproducible across machines.
# ─────────────────────────────────────────────
nvim/spell/*.spl
nvim/.netrwhist
nvim/sessions/
